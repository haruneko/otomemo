[Unit]
Description=creative_manager 音楽MCP (cm-music-mcp :8790)
# 注: アーキ是正 S2(音楽ドメインTS一本化)で廃止予定。完了後はこのユニットを無効化する。
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/projects/creative_manager/apps/worker
EnvironmentFile=-%h/.config/creative-manager.env
ExecStart=/usr/bin/env bash -lc 'exec uv run cm-music-mcp'
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
