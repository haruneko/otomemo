# creative_manager 環境設定（~/.config/creative-manager.env にコピーして編集）。
# systemd --user の各ユニットが EnvironmentFile=- で読む（無くても起動はする）。
# CM_DB は各ユニットが絶対パスで既定設定済み＝ここでの指定は任意（上書きしたい時だけ）。

# 出先(Tailscale)から届かせる：自分の Tailscale IP を入れる。未指定なら api は 127.0.0.1。
# CM_HOST=100.x.y.z

# 任意の追加ロック（tailnet 共有・LAN 開放するなら必須）。CM_HOST=0.0.0.0 で未設定だと api は起動拒否。
# CM_TOKEN=好きな長い文字列

# 意味hit較正ゲート閾値（既定 0.07）。agentic 上限ターン（既定 8）。
# CM_SEM_MIN_REL=0.07
# CM_AGENTIC_MAX_TURNS=8
